generator client { provider = "prisma-client-js" }
datasource db { provider = "sqlite" url = env("DATABASE_URL") }

enum AccountStatus { ACTIVE LOCKED ARCHIVED }
enum Scope { OWN ORGANIZATION GLOBAL }
enum DefinitionStatus { DRAFT PUBLISHED ARCHIVED }
enum InstanceStatus { RUNNING COMPLETED CANCELLED }
enum TaskStatus { OPEN CLAIMED COMPLETED CANCELLED }

model User { id String @id @default(uuid()) username String @unique displayName String passwordHash String status AccountStatus @default(ACTIVE) locale String @default("fa") failedLogins Int @default(0) lockedUntil DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt roles UserRole[] positions UserPosition[] refreshTokens RefreshToken[] submissions Submission[] tasks Task[] @relation("Assignee") claimedTasks Task[] @relation("Claimant") notifications Notification[] auditEvents AuditEvent[] @relation("Actor") }
model Role { id String @id @default(uuid()) name String @unique description String? archivedAt DateTime? users UserRole[] permissions RolePermission[] tasks Task[] }
model Permission { id String @id @default(uuid()) key String @unique description String? roles RolePermission[] }
model UserRole { userId String roleId String scope Scope @default(GLOBAL) organizationUnitId String? user User @relation(fields:[userId],references:[id]) role Role @relation(fields:[roleId],references:[id]) organizationUnit OrganizationUnit? @relation(fields:[organizationUnitId],references:[id]) @@id([userId,roleId]) }
model RolePermission { roleId String permissionId String role Role @relation(fields:[roleId],references:[id]) permission Permission @relation(fields:[permissionId],references:[id]) @@id([roleId,permissionId]) }
model OrganizationUnit { id String @id @default(uuid()) name String parentId String? archivedAt DateTime? parent OrganizationUnit? @relation("OrgTree",fields:[parentId],references:[id]) children OrganizationUnit[] @relation("OrgTree") positions Position[] roles UserRole[] tasks Task[] }
model Position { id String @id @default(uuid()) title String organizationUnitId String archivedAt DateTime? organizationUnit OrganizationUnit @relation(fields:[organizationUnitId],references:[id]) users UserPosition[] }
model UserPosition { userId String positionId String primary Boolean @default(false) user User @relation(fields:[userId],references:[id]) position Position @relation(fields:[positionId],references:[id]) @@id([userId,positionId]) }
model RefreshToken { id String @id @default(uuid()) userId String tokenHash String @unique familyId String expiresAt DateTime revokedAt DateTime? replacedById String? user User @relation(fields:[userId],references:[id]) createdAt DateTime @default(now()) }
model FormDefinition { id String @id @default(uuid()) name String archivedAt DateTime? createdAt DateTime @default(now()) versions FormVersion[] }
model FormVersion { id String @id @default(uuid()) definitionId String version Int status DefinitionStatus @default(DRAFT) schema Json publishedAt DateTime? definition FormDefinition @relation(fields:[definitionId],references:[id]) submissions Submission[] tasks Task[] @@unique([definitionId,version]) }
model Submission { id String @id @default(uuid()) formVersionId String ownerId String values Json createdAt DateTime @default(now()) updatedAt DateTime @updatedAt formVersion FormVersion @relation(fields:[formVersionId],references:[id]) owner User @relation(fields:[ownerId],references:[id]) attachments Attachment[] history SubmissionHistory[] workflowInstances WorkflowInstance[] }
model SubmissionHistory { id String @id @default(uuid()) submissionId String version Int values Json actorId String createdAt DateTime @default(now()) submission Submission @relation(fields:[submissionId],references:[id]) @@unique([submissionId,version]) }
model Attachment { id String @id @default(uuid()) submissionId String storageKey String @unique originalName String mimeType String size Int sha256 String createdAt DateTime @default(now()) submission Submission @relation(fields:[submissionId],references:[id]) }
model WorkflowDefinition { id String @id @default(uuid()) name String archivedAt DateTime? versions WorkflowVersion[] }
model WorkflowVersion { id String @id @default(uuid()) definitionId String version Int status DefinitionStatus @default(DRAFT) graph Json definition WorkflowDefinition @relation(fields:[definitionId],references:[id]) instances WorkflowInstance[] @@unique([definitionId,version]) }
model WorkflowInstance { id String @id @default(uuid()) workflowVersionId String submissionId String? status InstanceStatus @default(RUNNING) currentNodeId String variables Json version Int @default(0) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt workflowVersion WorkflowVersion @relation(fields:[workflowVersionId],references:[id]) submission Submission? @relation(fields:[submissionId],references:[id]) tasks Task[] transitions Transition[] }
model Task { id String @id @default(uuid()) instanceId String nodeId String name String status TaskStatus @default(OPEN) assigneeUserId String? assigneeRoleId String? assigneeOrganizationId String? claimantId String? formVersionId String? dueAt DateTime? priority Int @default(0) version Int @default(0) completedAt DateTime? instance WorkflowInstance @relation(fields:[instanceId],references:[id]) assigneeUser User? @relation("Assignee",fields:[assigneeUserId],references:[id]) assigneeRole Role? @relation(fields:[assigneeRoleId],references:[id]) assigneeOrganization OrganizationUnit? @relation(fields:[assigneeOrganizationId],references:[id]) claimant User? @relation("Claimant",fields:[claimantId],references:[id]) formVersion FormVersion? @relation(fields:[formVersionId],references:[id]) comments TaskComment[] idempotencies TaskCompletion[] @@index([status,assigneeUserId]) }
model TaskComment { id String @id @default(uuid()) taskId String authorId String body String createdAt DateTime @default(now()) task Task @relation(fields:[taskId],references:[id]) }
model TaskCompletion { id String @id @default(uuid()) taskId String idempotencyKey String result Json createdAt DateTime @default(now()) task Task @relation(fields:[taskId],references:[id]) @@unique([taskId,idempotencyKey]) }
model Transition { id String @id @default(uuid()) instanceId String fromNodeId String toNodeId String actorId String? variables Json createdAt DateTime @default(now()) instance WorkflowInstance @relation(fields:[instanceId],references:[id]) }
model MenuItem { id String @id @default(uuid()) parentId String? type String label Json route String? externalUrl String? permissionKey String? sortOrder Int @default(0) parent MenuItem? @relation("MenuTree",fields:[parentId],references:[id]) children MenuItem[] @relation("MenuTree") }
model Notification { id String @id @default(uuid()) userId String type String payload Json readAt DateTime? createdAt DateTime @default(now()) user User @relation(fields:[userId],references:[id]) @@index([userId,readAt]) }
model AuditEvent { id String @id @default(uuid()) actorId String? action String resourceType String resourceId String? correlationId String metadata Json createdAt DateTime @default(now()) actor User? @relation("Actor",fields:[actorId],references:[id]) @@index([action,resourceType,createdAt]) }
model ReportDefinition { id String @id @default(uuid()) name String source String columns Json filters Json permissionKey String createdAt DateTime @default(now()) }
