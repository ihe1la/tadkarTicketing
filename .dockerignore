# VCS and local tooling
.git
.github
.gitignore
.vscode
.agents
.codex
.editorconfig
.mimocode

# Package manager internals
.npm
.yarn
.pnpm-store

# Repository analysis and archived assets
archive
analysis
reference
docs

# Dependency and build outputs
node_modules
**/node_modules
**/dist
**/coverage
**/.angular
**/.cache
**/.turbo
**/.next
**/tmp
**/*.log
**/*.tsbuildinfo

# Local databases and runtime artifacts
**/*.db
**/*.db-journal
**/*.sqlite
**/*.sqlite3

# Environment files (local overrides only; manifests stay)
.env.local
.env.*.local
!.env.example

# OS and IDE files
.DS_Store
Thumbs.db
_tmp_*
*.swp
*.swo
*~
.idea
*.iml

# Docker artifacts (exclude from context to keep image lean)
**/.dockerignore
**/Dockerfile
docker-compose*.yml

# Test artifacts
**/.nyc_output
**/mocha.opts
**/.mocharc*
**/*~test.js

# Mandatory workspace files (needed for builds)
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!tsconfig.base.json
!eslint.config.mjs

# Source trees (apps and packages)
!apps/
!apps/**
!packages/
!packages/**

# Docker configs (needed by Dockerfile COPY commands)
!docker/
!docker/**

# Keep host dependency trees excluded after source-tree negations above.
**/node_modules
